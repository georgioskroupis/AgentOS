{
  "name": "agent-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-os": "./bin/agent-os"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:contracts": "node scripts/check-harness-contract.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "check:security": "node scripts/check-security.mjs",
    "coverage": "vitest run --coverage",
    "format:check": "node scripts/check-format.mjs",
    "lint": "node scripts/check-lint.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "agent-check": "bash scripts/agent-check.sh"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "liquidjs": "^10.24.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@openai/codex": "^0.125.0",
    "@types/node": "^24.10.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
